{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profiles"
    }
  }
}
